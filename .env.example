# ============================================================
# Ambient Expense Agent — environment variable template
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file — it is in .gitignore.
# ============================================================

# ---- Google AI Studio (recommended for local development) ----
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here
GOOGLE_API_KEY=your_api_key_here   # alias accepted by google-genai SDK

# Set to False for AI Studio, True for Vertex AI (requires gcloud ADC)
GOOGLE_GENAI_USE_VERTEXAI=False

# ---- Model selection (optional — defaults to gemini-flash-latest) ----
# Use any Gemini model name available in your account, e.g.:
#   gemini-2.0-flash, gemini-1.5-pro-latest, gemini-flash-latest
GEMINI_MODEL=gemini-3.1-flash-lite

# ---- Vertex AI (production / Cloud Run) ----
# Only needed when GOOGLE_GENAI_USE_VERTEXAI=True
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global

# ---- Optional observability ----
# LOGS_BUCKET_NAME=your-gcs-bucket-name
# ALLOW_ORIGINS=http://localhost:3000,https://your-frontend.com
